<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">
  <defs>
    <radialGradient id="bg192" cx="50%" cy="40%" r="60%">
      <stop offset="0%" stop-color="#141430"/>
      <stop offset="100%" stop-color="#0a0a1a"/>
    </radialGradient>
    <linearGradient id="cam192" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#00d4ff"/>
      <stop offset="100%" stop-color="#0090cc"/>
    </linearGradient>
    <filter id="glow192" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feComposite in="SourceGraphic" in2="blur" operator="over"/>
    </filter>
  </defs>

  <!-- Background circle -->
  <circle cx="96" cy="96" r="96" fill="url(#bg192)"/>

  <!-- Subtle ring border -->
  <circle cx="96" cy="96" r="93" fill="none" stroke="#00d4ff" stroke-opacity="0.15" stroke-width="1.5"/>

  <!-- Camera body -->
  <g filter="url(#glow192)" transform="translate(96, 78)">
    <!-- Camera body rounded rect -->
    <rect x="-40" y="-22" width="80" height="48" rx="8" ry="8"
          fill="none" stroke="url(#cam192)" stroke-width="3.5"/>

    <!-- Camera lens circle (outer) -->
    <circle cx="0" cy="2" r="14" fill="none" stroke="url(#cam192)" stroke-width="3"/>

    <!-- Camera lens circle (inner) -->
    <circle cx="0" cy="2" r="7" fill="none" stroke="#00d4ff" stroke-width="2" stroke-opacity="0.6"/>

    <!-- Camera lens dot -->
    <circle cx="0" cy="2" r="2.5" fill="#00d4ff" fill-opacity="0.8"/>

    <!-- Camera viewfinder bump -->
    <path d="M -12,-22 L -8,-32 L 8,-32 L 12,-22"
          fill="none" stroke="url(#cam192)" stroke-width="3" stroke-linejoin="round"/>

    <!-- Flash dot -->
    <circle cx="26" cy="-12" r="3" fill="#00d4ff" fill-opacity="0.5"/>

    <!-- Recording indicator -->
    <circle cx="-26" cy="-12" r="2.5" fill="#ff3b5c" fill-opacity="0.7"/>
  </g>

  <!-- ARLO text -->
  <text x="96" y="138" text-anchor="middle"
        font-family="'Segoe UI', 'Helvetica Neue', Arial, sans-serif"
        font-size="18" font-weight="700" letter-spacing="5" fill="#00d4ff">
    ARLO
  </text>

  <!-- Subtle tagline -->
  <text x="96" y="154" text-anchor="middle"
        font-family="'Segoe UI', 'Helvetica Neue', Arial, sans-serif"
        font-size="7" font-weight="400" letter-spacing="2" fill="#ffffff" fill-opacity="0.35">
    CAMERA
  </text>
</svg>
